{
  "mcpServers": {
    "kswitch-proxy": {
      "command": "kswitch-proxy",
      "env": {
        "KSWITCH_URL": "https://localhost:5001",
        "KSWITCH_TOKEN": "",
        "KSWITCH_CLIENT_ID": "kswitch-m2m",
        "KSWITCH_CLIENT_SECRET": "",
        "KSWITCH_KEYCLOAK_URL": "http://localhost:3001",
        "KSWITCH_KEYCLOAK_REALM": "kswitch",
        "KSWITCH_VERIFY_SSL": "true",
        "KSWITCH_PROXY_AGENT_ID": "claude-code-session",
        "KSWITCH_PROXY_UPSTREAMS": "[{\"id\": \"postgres-mcp\", \"command\": \"npx\", \"args\": [\"-y\", \"@mcp/postgres\", \"postgres://localhost/mydb\"]}, {\"id\": \"files-mcp\", \"command\": \"npx\", \"args\": [\"-y\", \"@mcp/filesystem\", \"/home/user/projects\"]}]"
      }
    }
  }
}
