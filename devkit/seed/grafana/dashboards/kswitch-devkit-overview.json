{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 0,
  "id": null,
  "uid": "kswitch-devkit-overview",
  "title": "KSwitch DevKit — Governance Overview",
  "description": "DevKit dashboard. Metric names verified against the live emitters in the KSwitch app. Developers can extend this dashboard with the full observability bundle in the production-shape tier.",
  "tags": ["kswitch", "devkit"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Enforcement decisions (last 5m)",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-devkit"},
      "targets": [
        {
          "expr": "sum(increase(kswitch_enforcement_decisions_total[5m]))",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Active kill switches",
      "id": 2,
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-devkit"},
      "targets": [
        {
          "expr": "sum(kswitch_kill_switches_active)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Auth failures (last 5m)",
      "id": 3,
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-devkit"},
      "targets": [
        {
          "expr": "sum(increase(kswitch_auth_failures_total[5m]))",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "JTI replays (last 5m)",
      "id": 4,
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus-devkit"},
      "targets": [
        {
          "expr": "sum(increase(kswitch_jti_replays_total[5m]))",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "timeseries",
      "title": "PDP decision latency (p50 / p95 / p99)",
      "description": "Source metric: kswitch_pdp_decision_duration_seconds (labeled by outcome, reason_class) — the live histogram emitted by the enforcement pipeline.",
      "id": 5,
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus-devkit"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kswitch_pdp_decision_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kswitch_pdp_decision_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kswitch_pdp_decision_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Enforcement decisions per second",
      "id": 6,
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus-devkit"},
      "targets": [
        {
          "expr": "sum(rate(kswitch_enforcement_decisions_total[1m]))",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "SIEM dispatch — dispatched vs dropped",
      "id": 7,
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus-devkit"},
      "targets": [
        {
          "expr": "sum(rate(kswitch_siem_dispatched_total[1m]))",
          "legendFormat": "dispatched",
          "refId": "A"
        },
        {
          "expr": "sum(rate(kswitch_siem_dropped_total[1m]))",
          "legendFormat": "dropped",
          "refId": "B"
        }
      ]
    }
  ]
}
