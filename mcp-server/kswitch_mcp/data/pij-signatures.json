  "description": "KSwitch indirect prompt injection (PIJ) signature catalogue. Canonical source — both app/content_inspection.py (EP-069) and kswitch_mcp/local_inspection.py (EP-072) compile from this file. Do not edit patterns in either module directly; edit here and run scripts/audit-pij-drift.py to verify sync.",
  "signatures": [
    {
      "id": "PIJ-001",
      "label": "Ignore previous instructions",
      "severity": "critical",
      "pattern": "ignore\\s+(all\\s+)?previous\\s+instructions?",
      "flags": "IGNORECASE"
    },
    {
      "id": "PIJ-002",
      "label": "System override",
      "severity": "critical",
      "pattern": "\\[?SYSTEM[\\s:]+(?:override|instruction)",
      "flags": "IGNORECASE"
    },
    {
