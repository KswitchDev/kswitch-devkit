# KSwitch Developer Edition — environment configuration
# ──────────────────────────────────────────────────
# Copy this file to `.env` and edit the values below before `make up`.
#
# Defaults are tuned for a single-host Docker install.

# ─── Developer Edition Licence assent ────────────────────────────────
# Required before `make up`.
#
# KSwitch Developer Edition is source-available for permitted
# non-commercial local use only. It is not open source. Commercial,
# production, customer-facing, internal business, managed-service,
# hosted, resale, or revenue-generating use requires a separate written
# KSwitch agreement.
#
# Read:
#   ../LICENSE.md
#   ../LICENSES/KSWITCH-DEVELOPER-EDITION-LICENSE.md
#   ../COMMERCIAL-USE.md
#
# Set to 1 only if you accept those terms.
KSWITCH_ACCEPT_DEVELOPER_EDITION_LICENSE=

# ─── Local developer identity ────────────────────────────────────────
# Lowercase letters, digits, hyphens. Used as the suffix on the admin
# user email (admin@<KSWITCH_CUSTOMER_ID>) and in local SPIFFE IDs.
KSWITCH_CUSTOMER_ID=developer-local

# ─── Deployment target ────────────────────────────────────────────────
# Switches the seed.sh / seed-reset.sh / doctor.sh secret-storage
# strategy. Per §F lifecycle: laptop / on-prem write the bundled admin
# password to ./state/initial-admin.txt (mode 600). Cloud / K8s targets
# never write a host file — they write to the cloud-native secret
# manager instead (G33 / G37).
#
# Allowed values:
#   laptop        — Docker Desktop on a developer workstation (default)
#   on-prem       — Linux host with Docker installed
# Developer Edition supports the local single-host targets only.
KSWITCH_DEPLOYMENT_TARGET=laptop

# ─── Service endpoints (defaults work for `make up`) ──────────────────
# These match the bundled docker-compose.yml service ports.
KEYCLOAK_URL=http://localhost:3001
KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD — master Keycloak realm-admin password. Used
# only by the bundle's seed.sh + doctor.sh to call the Keycloak admin
# REST API on first install. Developer-facing sign-in uses a SEPARATE
# user created by seed.sh, not this one.
#
# REQUIRED — you MUST set this to a strong value before `make up`.
# The placeholder default `CHANGE-ME-developer-keycloak` is rejected by
# `make preflight`. The bundle will refuse to boot until you change it.
KEYCLOAK_ADMIN_PASSWORD=CHANGE-ME-developer-keycloak

# ─── Developer Edition hard caps ──────────────────────────────────────
# These are enforced inside the app by the Developer Edition loader
# overlay. They are documented here for clarity; they are not a licence
# file and there is no renewal flow.
# agents=10, mcps=10, tools=100, skills=100

# ─── Image tag (default: floating MINOR per §E) ───────────────────────
# Update by bumping this and running `make pull && make up`.
KSWITCH_IMAGE_TAG=v1.36-pg

# ─── Doctor thresholds (override only if you know what you're doing) ──
# Hours-to-expiry threshold that flips `make doctor` from PASS to WARN
# on the bundled-password time-bomb (G20b). FAIL is fixed at 0 (expired).
KSWITCH_BUNDLED_PASSWORD_WARN_HOURS=12

# ─── TLS (defaults to make tls auto-generation) ───────────────────────
# To use enterprise CA-signed certs, drop them at the paths below and
# `make tls` becomes a no-op.
TLS_CERT_PATH=./tls/cert.pem
TLS_KEY_PATH=./tls/key.pem
