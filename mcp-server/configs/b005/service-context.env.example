# B005.2 managed service gateway context
# Copy into the deployment secret/config system, not into source control.
# Human IdP values may point at Entra, Ping, Okta, ForgeRock, SlashID,
# AD federation, or any standards-compliant OIDC provider.
# Workload authority for B005 service dispatch remains SPIFFE JWT-SVID.

AUTH_DISABLED=false

# Human / service-account OIDC validation.
OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_AUDIENCE=api://kswitch-atcp
OIDC_TENANT_ID=<tenant-id>
OIDC_CLIENT_ID=<kswitch-ui-client-id>
OIDC_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
ROLE_CLAIM_PATH=roles,realm_access.roles,groups
GROUP_CLAIM_PATH=groups

# Workload identity validation for governed B005 service calls.
SPIFFE_JWT_ENABLED=true
SPIFFE_JWKS_URI=https://spire.example.internal/jwks
SPIFFE_ALLOWED_TRUST_DOMAINS=bank.internal,kswitch.ai

# Operator-owned B005 registry/profile context. These values are used by
# app/b005_service_context.py after auth_middleware has validated SPIFFE JWT-SVID.
B005_TENANT_ID=tenant-alpha
B005_CUSTOMER_ID=customer-bank-a
B005_SERVICE_REGISTRY_ID=registry-b005-demo
B005_SERVICE_REGISTRY_VERSION=2026-05-28.1
B005_CONTEXT_SERVICE_ID=public_https
B005_MODE=managed
B005_GOVERNANCE_PROFILE_ID=governance-profile-managed
B005_POLICY_SCOPE=tenant
B005_POLICY_BUNDLE=sha256:1111111111111111111111111111111111111111111111111111111111111111
B005_DEVICE_TRUST_LEVEL=managed
B005_DEVICE_ID=device-managed-001
B005_AGENT_RUNTIME=codex-desktop
B005_AGENT_SESSION_ID=agent-session-001
B005_WORKSPACE_ID=workspace-prod-001
B005_COMPLIANCE_FRAMEWORKS=soc_2,nist_800_53,iso_27001,eu_dora,nist_ai_rmf,eu_ai_act,owasp_llm

# Optional customer fetch allowlist. Empty means the B005 hard-deny checks still
# apply, but no customer-specific host policy is enforced by this gateway.
# Use exact hosts or wildcard subdomain patterns. Do not include schemes/paths.
B005_FETCH_ALLOWED_HOSTS=example.com,*.docs.example.com

# Optional customer search provider registry for B005.3 W1. Empty means
# kswitch_service.search fails closed before adapter dispatch. Values are
# tenant-owned provider approvals; query text is still minimized before adapter
# invocation by the service core.
B005_SEARCH_PROVIDER_REGISTRY_JSON={"customer_search_default":{"service_provider":"customer_search","service_id":"customer_search_default","owner":"customer-bank-a","retention_class":"metadata_only","evidence_policy":"b005-search-default","health":"available","enabled":true}}

# Optional customer search data policy for B005.3 W2. Omit or set deny in
# production until the HITL connector path has customer-specific evidence.
B005_SEARCH_POLICY_JSON={"regulated_data_action":"hitl_required","customer_confidential_action":"deny"}
